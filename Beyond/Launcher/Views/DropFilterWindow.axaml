<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Launcher.ViewModels"
        xmlns:v="using:Launcher.Views"
        x:Class="Launcher.Views.DropFilterWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Drop Filter"
        Width="400" Height="580"
        Background="#0F0F11"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="30"
        WindowDecorations="BorderOnly">

    <DockPanel Classes="WindowRoot">
        <v:TitleBar DockPanel.Dock="Top" Title="Drop Filter"/>

        <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Instructions -->
                <Border Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Keep drops are looted into your inventory; Reject drops are dusted. Anything in neither list is left in the drop window." Foreground="#8F909A" FontSize="9" TextWrapping="Wrap"/>
                        <TextBlock Text="Comma-separated. Use Name, an item ID, or Name:rarity for gems (common, uncommon, rare, epic, legendary, mythic). A bare name matches any rarity. Use *gem:rarity to match ANY gem of a tier (or *gem for any gem)." Foreground="#656770" FontSize="9" TextWrapping="Wrap"/>
                        <TextBlock Text="e.g. Lucky Cape Gem:rare, *gem:legendary, Blinding Light of Destiny" Foreground="#656770" FontSize="9" FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Keep List -->
                <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Keep (loot to inventory)" Classes="Header" Margin="0"/>
                        <TextBox Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" Padding="8" CornerRadius="4" Foreground="#E2E4E9" Text="{Binding KeepListInput}" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <CheckBox IsChecked="{Binding DeleteOthers}" Foreground="#E2E4E9" FontSize="11" Content="Delete all other drops (keep only the items listed above)"/>
                    </StackPanel>
                </Border>

                <!-- Reject List -->
                <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12" IsEnabled="{Binding RejectEnabled}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Reject (dust)" Classes="Header" Margin="0"/>
                        <TextBox Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" Padding="8" CornerRadius="4" Foreground="#E2E4E9" Text="{Binding RejectListInput}" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <TextBlock Text="{Binding DropFilterStatus}" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" TextWrapping="Wrap" MinHeight="30" VerticalAlignment="Center"/>
                </Border>

                <!-- Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto">
                    <Button Grid.Column="0" Content="{Binding FilterToggleLabel}" Command="{Binding ToggleDropFilterCommand}" Height="36" FontSize="12" FontWeight="Bold"/>
                    <Button Grid.Column="1" Content="Clear Filter" Command="{Binding ClearDropFilterCommand}" Height="36" FontSize="12" FontWeight="Bold"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
