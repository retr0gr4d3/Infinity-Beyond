<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Launcher.ViewModels"
        xmlns:v="using:Launcher.Views"
        x:Class="Launcher.Views.DropFilterWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Drop Filter"
        Width="400" Height="580"
        Background="#0F0F11"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="30"
        WindowDecorations="BorderOnly">

    <DockPanel Classes="WindowRoot">
        <v:TitleBar DockPanel.Dock="Top" Title="Drop Filter"/>

        <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Instructions -->
                <Border Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="10">
                    <TextBlock Text="Filter by items AND/OR rarities. Both optional." Foreground="#8F909A" FontSize="9" TextWrapping="Wrap"/>
                </Border>

                <!-- Items Filter -->
                <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Items (optional)" Classes="Header" Margin="0"/>
                        <TextBlock Text="Comma-separated. Multi-word names like this: Thief Armor Gem,Lucky Cape Gem,1,2" FontSize="9" Foreground="#656770" TextWrapping="Wrap"/>
                        <TextBox Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" Padding="8" CornerRadius="4" Foreground="#E2E4E9" Text="{Binding ItemsFilterInput}" MinHeight="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Border>

                <!-- Rarities Filter -->
                <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Rarities (optional)" Classes="Header" Margin="0"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <TextBlock Text="Common" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding FilterRarityCommon}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Text="Uncommon" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding FilterRarityUncommon}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="Rare" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding FilterRarityRare}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Text="Epic" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding FilterRarityEpic}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Text="Legendary" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding FilterRarityLegendary}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="5" Text="Mythic" Foreground="#E2E4E9" FontSize="11" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding FilterRarityMythic}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action -->
                <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Action" Classes="Header" Margin="0"/>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                            <RadioButton Grid.Column="0" GroupName="DropFilterAction" Content="Accept (Keep matching)" IsChecked="{Binding FilterActionAccept}" Foreground="#E2E4E9" FontSize="11"/>
                            <RadioButton Grid.Column="1" GroupName="DropFilterAction" Content="Reject (Block matching)" IsChecked="{Binding FilterActionReject}" Foreground="#E2E4E9" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Background="#16161A" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                    <TextBlock Text="{Binding DropFilterStatus}" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" TextWrapping="Wrap" MinHeight="30" VerticalAlignment="Center"/>
                </Border>

                <!-- Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto">
                    <Button Grid.Column="0" Content="{Binding FilterToggleLabel}" Command="{Binding ToggleDropFilterCommand}" Height="36" FontSize="12" FontWeight="Bold"/>
                    <Button Grid.Column="1" Content="Clear Filter" Command="{Binding ClearDropFilterCommand}" Height="36" FontSize="12" FontWeight="Bold"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
