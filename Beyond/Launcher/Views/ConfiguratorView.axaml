<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Launcher.ViewModels"
             x:Class="Launcher.Views.ConfiguratorView"
             x:CompileBindings="False"
             Background="#0F0F11"
             FontFamily="Inter, Segoe UI, sans-serif">

    <Design.DataContext>
        <vm:ConfiguratorViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style Selector="TextBlock.Label">
            <Setter Property="Foreground" Value="#C5C7D0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#16161A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#26262E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondAccentBrush}"/>
        </Style>
        <Style Selector="ColorPicker TextBox">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentDimBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentContrastBrush}"/>
        </Style>
        <Style Selector="Button.Accent">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentDimBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentBrush}"/>
        </Style>
        <Style Selector="Button.Accent:pointerover">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentContrastBrush}"/>
        </Style>
        <!-- Override Fluent's grey content-presenter hover fill with the accent. -->
        <Style Selector="Button:not(.Danger):not(.CloseTab):not(.Link):pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentBrush}"/>
        </Style>
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="{DynamicResource BeyondDangerDimBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondDangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondDangerBrush}"/>
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="{DynamicResource BeyondDangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondDangerContrastBrush}"/>
        </Style>
        <!-- Fluent's grey content-presenter hover fill hides the red above; override it. -->
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BeyondDangerBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*, 1.5*" Margin="40">
        <!-- Left Column: Unified Configuration Panel -->
        <Border Grid.Column="0" Background="#141418" BorderBrush="#202026" BorderThickness="1" CornerRadius="8" Padding="25" VerticalAlignment="Top" Margin="0,0,20,0">
            <StackPanel>
                <!-- Add Account Section -->
                <TextBlock Text="ADD GAME ACCOUNT" Classes="SectionHeader"/>

                <TextBlock Text="USERNAME" Classes="Label"/>
                <TextBox Text="{Binding NewUsername, Mode=TwoWay}" PlaceholderText="Enter game username..."/>

                <TextBlock Text="NICKNAME" Classes="Label"/>
                <TextBox Text="{Binding NewNickname, Mode=TwoWay}" PlaceholderText="Display name (hides player ID)..."/>

                <TextBlock Text="PASSWORD" Classes="Label"/>
                <TextBox Text="{Binding NewPassword, Mode=TwoWay}" PasswordChar="*" PlaceholderText="Enter game password..."/>

                <Button Content="Add Account" Classes="Accent" Command="{Binding AddAccountCommand}" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                <Separator Height="1" Background="#202026" Margin="0,20"/>

                <!-- Game Directory Section -->
                <TextBlock Text="GAME DIRECTORY" Classes="Label"/>
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBox Grid.Column="0" Text="{Binding GameDirectory, Mode=TwoWay}" PlaceholderText="Select game folder..." Margin="0"/>
                    <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseDirectoryCommand}" Margin="8,0,0,0" Padding="12,8"/>
                </Grid>

                <Separator Height="1" Background="#202026" Margin="0,20"/>

                <!-- Appearance Section -->
                <TextBlock Text="APPEARANCE" Classes="SectionHeader"/>
                <TextBlock Text="Personalize the app's colors." Foreground="#8F909A" FontSize="11" Margin="0,0,0,16"/>

                <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="20">
                    <!-- Accent Color Picker -->
                    <StackPanel Grid.Column="0" Spacing="6" ToolTip.Tip="Buttons, highlights, sliders and glow">
                        <TextBlock Text="Accent" Foreground="#E2E4E9" FontSize="12" FontWeight="SemiBold"/>
                        <ColorPicker Color="{Binding AccentColor, Mode=TwoWay}" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Danger Color Picker -->
                    <StackPanel Grid.Column="1" Spacing="6" ToolTip.Tip="Remove, close and Configurator buttons">
                        <TextBlock Text="Danger" Foreground="#E2E4E9" FontSize="12" FontWeight="SemiBold"/>
                        <ColorPicker Color="{Binding DangerColor, Mode=TwoWay}" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Single Reset Button -->
                    <Button Grid.Column="2" Content="Reset" Command="{Binding ResetCommand}" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Right Column: Account List & Launch Actions -->
        <Border Grid.Column="1" Background="#141418" BorderBrush="#202026" BorderThickness="1" CornerRadius="8" Padding="25" Margin="20,0,0,0">
            <Grid RowDefinitions="Auto, *, Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                    <TextBlock Grid.Column="0" Text="CONFIGURED ACCOUNTS" Classes="SectionHeader" VerticalAlignment="Center" Margin="0"/>
                    <Button Grid.Column="1" Content="🚀 Launch All Sessions" Classes="Accent" Command="{Binding LaunchAllCommand}" 
                            IsEnabled="{Binding Accounts.Count}" Padding="16,8"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1C1D24" BorderBrush="#2F303B" BorderThickness="1" CornerRadius="6" Padding="15,10" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*, Auto, Auto">
                                        <!-- Account Details -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayText}" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="Stored Credentials" Foreground="#8F909A" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <Button Grid.Column="1" Content="Launch Session" Classes="Accent" 
                                                Command="{Binding DataContext.LaunchAccountCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                        
                                        <Button Grid.Column="2" Content="Remove" Classes="Danger"
                                                Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty State Message -->
                <TextBlock Grid.Row="1" Text="No accounts added yet. Use the left panel to configure your accounts." 
                           Foreground="#8F909A" FontSize="13" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"
                           IsVisible="{Binding !Accounts.Count}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
