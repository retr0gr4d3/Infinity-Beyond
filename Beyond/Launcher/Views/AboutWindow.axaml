<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Launcher.Views.AboutWindow"
        x:CompileBindings="False"
        Title="About Beyond"
        Background="#0F0F11"
        FontFamily="Inter, Segoe UI, sans-serif"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        SizeToContent="Height"
        Width="420">

    <Window.Styles>
        <Style Selector="Button.Accent">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentDimBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.Accent:pointerover">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentContrastBrush}"/>
        </Style>
        <!-- Override Fluent's grey content-presenter hover fill with the accent. -->
        <Style Selector="Button.Accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BeyondAccentBrush}"/>
        </Style>
        <Style Selector="Button.Link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.Link:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource BeyondAccentLightBrush}"/>
        </Style>
        <Style Selector="Button.Link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <Border Padding="26,24" BorderBrush="#2A2A32" BorderThickness="1" PointerPressed="OnDragPressed">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
            <!-- Logo emblem -->
            <Border Width="76" Height="76" CornerRadius="18" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource BeyondAccentBrush}" BorderThickness="1.5" BoxShadow="{DynamicResource BeyondGlowEmblem}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Offset="0" Color="#15262B"/>
                        <GradientStop Offset="1" Color="#101619"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Image Source="/Assets/Beyond.png" Width="50" Height="50"
                       RenderOptions.BitmapInterpolationMode="HighQuality"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Title -->
            <StackPanel Spacing="3" HorizontalAlignment="Center">
                <TextBlock Text="Beyond" Foreground="#FFFFFF" FontSize="21" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="AdventureQuest Worlds: Infinity Client" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Metadata -->
            <StackPanel Spacing="2" HorizontalAlignment="Center">
                <TextBlock Name="VersionText" Text="Version 0.1.4" Foreground="#8F909A" FontSize="11"
                           HorizontalAlignment="Center"/>
                <TextBlock Name="BuildDateText" Text="" Foreground="#656770" FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- GitHub link -->
            <Button Classes="Link" Click="OpenGitHubClick" HorizontalAlignment="Center"
                    ToolTip.Tip="https://github.com/retr0gr4d3/Infinity-Beyond">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource BeyondAccentBrush}" VerticalAlignment="Center"
                          Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    <TextBlock Text="github.com/retr0gr4d3/Infinity-Beyond" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Border Height="1" Background="#202026" Margin="0,2"/>

            <!-- Credits -->
            <StackPanel Spacing="2" HorizontalAlignment="Center">
                <!--<TextBlock Text="CREDITS" Foreground="#8F909A" FontSize="10" FontWeight="Bold"
                           LetterSpacing="1.5" HorizontalAlignment="Center"/>
                <TextBlock Text="Crafted by Retr0gr4d3" Foreground="#C5C7D0" FontSize="11"
                           HorizontalAlignment="Center"/>-->
                <TextBlock Text="© 2026 Retr0gr4d3 · All rights reserved" Foreground="#656770" FontSize="10"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Button Content="Close" Classes="Accent" Width="110" HorizontalAlignment="Center" Click="CloseClick"/>
        </StackPanel>
    </Border>
</Window>
