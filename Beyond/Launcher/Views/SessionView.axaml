<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Launcher.ViewModels"
             xmlns:local="using:Launcher"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Launcher.Views.SessionView"
             x:DataType="vm:MainWindowViewModel"
             Background="#0F0F11">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="ToggleButton.CollapseToggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ToggleButton.CollapseToggle /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.CollapseToggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.CollapseToggle:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.CollapseToggle:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="Auto,Auto,*">
        <!-- Collapsible Sidebar Panel -->
        <Border Grid.Column="0" Name="Sidebar" Width="380" Background="#141418" BorderBrush="#202026" BorderThickness="0,0,1,0" IsVisible="{Binding #CollapseToggleHandle.IsChecked}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header/Status Area -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="15,15,15,10">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BEYOND" FontSize="16" FontWeight="Black" Foreground="#FFFFFF" LetterSpacing="1"/>
                        <TextBlock Text="Control Panel" FontSize="10" Foreground="#656770"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1C1D24" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#C5C7D0" FontWeight="Bold"/>
                            </StackPanel>
                            <Border Width="1" Height="10" Background="#2A2A32" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="8" Height="8" Fill="{Binding MelonLoaderStatusColor}"/>
                                <TextBlock Text="{Binding MelonLoaderStatusText}" FontSize="10" Foreground="#C5C7D0" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Separator Grid.Row="0" Margin="0" Height="1" Background="#202026" VerticalAlignment="Bottom"/>

                <!-- Scroll Area for controls -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10" IsVisible="{Binding IsControlPanelEnabled}">
                    <StackPanel Spacing="12">
                        <!-- Direct Controls -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="0">
                                <ToggleButton Classes="CollapseToggle" Name="ToggleQuickActions" IsChecked="True">
                                    <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                                        <TextBlock Text="Quick Actions" Classes="Header" VerticalAlignment="Center" Margin="0"/>
                                        <Panel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock Text="▲" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding #ToggleQuickActions.IsChecked}"/>
                                            <TextBlock Text="▼" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding !#ToggleQuickActions.IsChecked}"/>
                                        </Panel>
                                    </Grid>
                                </ToggleButton>

                                <StackPanel Spacing="10" Margin="0,10,0,0" IsVisible="{Binding #ToggleQuickActions.IsChecked}">
                                    <!-- Camera Distance slider -->
                                    <StackPanel Spacing="3">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Camera Distance" FontSize="11" Foreground="#C5C7D0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="Reset" Command="{Binding ResetCameraZoomCommand}" Padding="5,2" FontSize="10"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Slider Minimum="0.5" Maximum="3.0" Value="{Binding CameraZoom}" HorizontalAlignment="Stretch" Grid.Column="0"/>
                                            <TextBlock Text="{Binding CameraZoom, StringFormat='{}{0:0.0}x'}" Width="35" FontSize="11" Foreground="{DynamicResource BeyondAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>

                                    <Separator Height="1" Background="#202026" Margin="0,2"/>

                                    <!-- Cutscene skipping -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Cutscene Auto-Skip" VerticalAlignment="Center" FontSize="12" Foreground="#E2E4E9"/>
                                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoSkipCutscenes}"/>
                                    </Grid>
                                    <Button Content="Skip Active Cutscene Now" Command="{Binding SkipCutsceneCommand}" HorizontalAlignment="Stretch" Height="28"/>

                                    <Separator Height="1" Background="#202026" Margin="0,2"/>

                                    <!-- Framerate Tools -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Framerate Tools" FontSize="11" Foreground="#C5C7D0"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="VSync" VerticalAlignment="Center" FontSize="12" Foreground="#E2E4E9"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsVSyncEnabled}"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Uncap Frames" VerticalAlignment="Center" FontSize="12" Foreground="#E2E4E9"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding UncapFrames}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Module Launchers -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="0">
                                <ToggleButton Classes="CollapseToggle" Name="ToggleLauncherModules" IsChecked="True">
                                    <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                                        <TextBlock Text="Launcher Modules" Classes="Header" VerticalAlignment="Center" Margin="0"/>
                                        <Panel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock Text="▲" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding #ToggleLauncherModules.IsChecked}"/>
                                            <TextBlock Text="▼" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding !#ToggleLauncherModules.IsChecked}"/>
                                        </Panel>
                                    </Grid>
                                </ToggleButton>

                                <Grid Margin="0,10,0,0" IsVisible="{Binding #ToggleLauncherModules.IsChecked}" ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <Button Grid.Row="0" Grid.Column="0" Content="Fake Dev Options" Command="{Binding OpenFakeDevWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Spoofers &amp; Jukebox" Command="{Binding OpenSpoofersWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="0" Content="Shop Loader" Command="{Binding OpenShopLoaderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="1" Content="Quest Loader" Command="{Binding OpenQuestLoaderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="2" Grid.Column="0" Content="Autoskills (Retro)" Command="{Binding OpenAutoskillsCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="2" Grid.Column="1" Content="Quest Runner" Command="{Binding OpenQuestRunnerWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- Packet Tools launchers -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="0">
                                <ToggleButton Classes="CollapseToggle" Name="TogglePacketTools" IsChecked="True">
                                    <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                                        <TextBlock Text="Packet Tools Suite" Classes="Header" VerticalAlignment="Center" Margin="0"/>
                                        <Panel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock Text="▲" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding #TogglePacketTools.IsChecked}"/>
                                            <TextBlock Text="▼" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding !#TogglePacketTools.IsChecked}"/>
                                        </Panel>
                                    </Grid>
                                </ToggleButton>

                                <Grid Margin="0,10,0,0" IsVisible="{Binding #TogglePacketTools.IsChecked}" ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <Button Grid.Row="0" Grid.Column="0" Content="Interceptor" Command="{Binding OpenInterceptorWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Sniffer" Command="{Binding OpenSnifferWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="0" Content="Sender" Command="{Binding OpenSenderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="1" Content="Receiver" Command="{Binding OpenReceiverWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- Event Logs display -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="0">
                                <ToggleButton Classes="CollapseToggle" Name="ToggleEventLogs" IsChecked="True">
                                    <Grid ColumnDefinitions="*,Auto" Background="Transparent">
                                        <TextBlock Text="Event Terminal Logs" Classes="Header" VerticalAlignment="Center" Margin="0"/>
                                        <Panel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <TextBlock Text="▲" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding #ToggleEventLogs.IsChecked}"/>
                                            <TextBlock Text="▼" Foreground="{DynamicResource BeyondAccentBrush}" FontSize="10" IsVisible="{Binding !#ToggleEventLogs.IsChecked}"/>
                                        </Panel>
                                    </Grid>
                                </ToggleButton>

                                <ListBox Margin="0,8,0,0" IsVisible="{Binding #ToggleEventLogs.IsChecked}" Background="#16161A" BorderThickness="1" BorderBrush="#202026" CornerRadius="4" Height="100" ItemsSource="{Binding GeneralLogs}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="x:String">
                                            <TextBlock Text="{Binding}" Foreground="#8F909A" FontSize="9" TextWrapping="Wrap" Margin="2,1"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Warning message when MelonLoader is detected -->
                <Border Grid.Row="1" Background="#2D1C1C" BorderBrush="#FF5252" BorderThickness="1" CornerRadius="8" Padding="25" Margin="15" VerticalAlignment="Center" IsVisible="{Binding IsMelonLoaderDetected}">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="⚠ MODIFICATIONS DISABLED" Foreground="#FF5252" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" LetterSpacing="0.5"/>
                        <TextBlock Text="Beyond has disabled its built-in modifications as MelonLoader was detected." Foreground="#E2E4E9" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" LineHeight="16"/>
                    </StackPanel>
                </Border>

                <!-- Footer Area -->
                <Separator Grid.Row="2" Margin="0" Height="1" Background="#202026" VerticalAlignment="Top"/>
                <TextBlock Grid.Row="2" Text="v0.1.1 (Beyond Standalone Edition)" FontSize="9" Foreground="#44454E" HorizontalAlignment="Center" Margin="10,12"/>
            </Grid>
        </Border>

        <!-- Always-visible collapse handle. Lives inside the main window (its own
             Avalonia column, beside the native game host) so it is NOT a separate
             OS-level window — Discord/OBS won't see it as a capturable surface. -->
        <Border Grid.Column="1" Name="HandleRail" Width="20" Background="#141418" BorderBrush="#202026" BorderThickness="0,0,1,0">
            <ToggleButton Name="CollapseToggleHandle" Classes="CollapseToggle" IsChecked="True"
                          Width="20" Height="40"
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          Padding="0" Focusable="False"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                          ToolTip.Tip="Toggle Control Panel">
                <TextBlock Text="⇋" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BeyondAccentBrush}"/>
            </ToggleButton>
        </Border>

        <!-- Embedded Unity Game Viewer -->
        <Grid Grid.Column="2" Background="#000000">
            <local:UnityWindowHost PipeName="{Binding SessionPipeName}"
                                   PresetUsername="{Binding PresetUsername}"
                                   PresetPassword="{Binding PresetPassword}"
                                   PresetNickname="{Binding PresetNickname}"
                                   GameDirectory="{Binding GameDirectory}" />
        </Grid>
    </Grid>
</UserControl>
