<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Launcher.ViewModels"
             xmlns:local="using:Launcher"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Launcher.Views.SessionView"
             x:DataType="vm:MainWindowViewModel"
             Background="#0F0F11">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="Auto,*">
        <!-- Collapsible Sidebar Panel -->
        <Border Grid.Column="0" Name="Sidebar" Width="380" Background="#141418" BorderBrush="#202026" BorderThickness="0,0,1,0" IsVisible="True">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header/Status Area -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="15,15,15,10">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BEYOND" FontSize="16" FontWeight="Black" Foreground="#FFFFFF" LetterSpacing="1"/>
                        <TextBlock Text="Control Panel" FontSize="10" Foreground="#656770"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1C1D24" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#C5C7D0" FontWeight="Bold"/>
                            </StackPanel>
                            <Border Width="1" Height="10" Background="#2A2A32" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="8" Height="8" Fill="{Binding MelonLoaderStatusColor}"/>
                                <TextBlock Text="{Binding MelonLoaderStatusText}" FontSize="10" Foreground="#C5C7D0" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Separator Grid.Row="0" Margin="0" Height="1" Background="#202026" VerticalAlignment="Bottom"/>

                <!-- Scroll Area for controls -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10" IsVisible="{Binding IsControlPanelEnabled}">
                    <StackPanel Spacing="12">
                        <!-- Direct Controls -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Quick Actions" Classes="Header" Margin="0"/>

                                <!-- Camera Zoom view slider -->
                                <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Camera Zoom View" FontSize="11" Foreground="#C5C7D0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Reset" Command="{Binding ResetCameraZoomCommand}" Padding="5,2" FontSize="10"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Slider Minimum="0.5" Maximum="3.0" Value="{Binding CameraZoom}" HorizontalAlignment="Stretch" Grid.Column="0"/>
                                        <TextBlock Text="{Binding CameraZoom, StringFormat='{}{0:0.0}x'}" Width="35" FontSize="11" Foreground="#00E5FF" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="1"/>
                                    </Grid>
                                </StackPanel>

                                <Separator Height="1" Background="#202026" Margin="0,2"/>

                                <!-- Cutscene skipping -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Cutscene Auto-Skip" VerticalAlignment="Center" FontSize="12" Foreground="#E2E4E9"/>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoSkipCutscenes}"/>
                                </Grid>
                                <Button Content="Skip Active Cutscene Now" Command="{Binding SkipCutsceneCommand}" HorizontalAlignment="Stretch" Height="28"/>
                            </StackPanel>
                        </Border>

                        <!-- Module Launchers -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Launcher Modules" Classes="Header" Margin="0"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                    <Button Grid.Row="0" Grid.Column="0" Content="Fake Dev Options" Command="{Binding OpenFakeDevWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Spoofers &amp; Jukebox" Command="{Binding OpenSpoofersWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="0" Content="Shop Loader" Command="{Binding OpenShopLoaderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="1" Content="Quest Loader" Command="{Binding OpenQuestLoaderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="2" Grid.Column="0" Content="Autoskills (Retro)" Command="{Binding OpenAutoskillsCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="2" Grid.Column="1" Content="Quest Runner" Command="{Binding OpenQuestRunnerWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Packet Tools launchers -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Packet Tools Suite" Classes="Header" Margin="0"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <Button Grid.Row="0" Grid.Column="0" Content="Interceptor" Command="{Binding OpenInterceptorWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Sniffer" Command="{Binding OpenSnifferWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="0" Content="Sender" Command="{Binding OpenSenderWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                    <Button Grid.Row="1" Grid.Column="1" Content="Receiver" Command="{Binding OpenReceiverWindowCommand}" HorizontalAlignment="Stretch" Height="30"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Event Logs display -->
                        <Border Background="#1C1D24" BorderBrush="#2A2A32" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Event Terminal Logs" Classes="Header" Margin="0"/>
                                <ListBox Background="#16161A" BorderThickness="1" BorderBrush="#202026" CornerRadius="4" Height="100" ItemsSource="{Binding GeneralLogs}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="x:String">
                                            <TextBlock Text="{Binding}" Foreground="#8F909A" FontSize="9" TextWrapping="Wrap" Margin="2,1"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Warning message when MelonLoader is detected -->
                <Border Grid.Row="1" Background="#2D1C1C" BorderBrush="#FF5252" BorderThickness="1" CornerRadius="8" Padding="25" Margin="15" VerticalAlignment="Center" IsVisible="{Binding IsMelonLoaderDetected}">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="⚠ MODIFICATIONS DISABLED" Foreground="#FF5252" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" LetterSpacing="0.5"/>
                        <TextBlock Text="Beyond has disabled its built in modifications as MelonLoader was detected." Foreground="#E2E4E9" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" LineHeight="16"/>
                    </StackPanel>
                </Border>

                <!-- Footer Area -->
                <Separator Grid.Row="2" Margin="0" Height="1" Background="#202026" VerticalAlignment="Top"/>
                <TextBlock Grid.Row="2" Text="v0.1.0 (Beyond Standalone Edition)" FontSize="9" Foreground="#44454E" HorizontalAlignment="Center" Margin="10,12"/>
            </Grid>
        </Border>

        <!-- Embedded Unity Game Viewer & Floating Splitter Overlay -->
        <Grid Grid.Column="1" Background="#000000">
            <local:UnityWindowHost PipeName="{Binding SessionPipeName}"
                                   PresetUsername="{Binding PresetUsername}"
                                   PresetPassword="{Binding PresetPassword}"
                                   PresetNickname="{Binding PresetNickname}"
                                   GameDirectory="{Binding GameDirectory}" />

            <!-- Invisible anchor at the left edge of the game area, vertically centered -->
            <Control Name="PopupAnchor" Width="0" Height="0" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="True"/>

            <!-- Floating Toggle Button Popup (draws on top of native Win32 window) -->
            <Popup Name="CollapseButtonPopup" IsOpen="True" IsLightDismissEnabled="False"
                   PlacementTarget="{Binding #PopupAnchor}" Placement="Right">
                <ToggleButton Name="CollapseButton" 
                              Width="20" Height="40"
                              IsChecked="{Binding #Sidebar.IsVisible, Mode=TwoWay}"
                              CornerRadius="0,4,4,0"
                              BorderThickness="0,1,1,1"
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0">
                    <TextBlock Text="⇋" Foreground="#00E5FF" FontSize="14" FontWeight="Bold"/>
                </ToggleButton>
            </Popup>
        </Grid>
    </Grid>
</UserControl>
