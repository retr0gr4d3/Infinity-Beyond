<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Launcher.Views.TitleBar"
             x:Name="Root"
             x:CompileBindings="False">

    <!-- Custom window chrome shared by every tool window. Mirrors the main
         window's title bar so the whole app looks like one piece. -->
    <Border Height="30" Background="#0F0F11"
            PointerPressed="OnDragPressed" DoubleTapped="OnTitleBarDoubleTapped">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Stretch">
            <!-- Title (click-through so the whole strip stays draggable) -->
            <TextBlock Grid.Column="0" Text="{Binding #Root.Title}" Foreground="#00E5FF" FontSize="11"
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"
                       IsHitTestVisible="False"/>

            <!-- Caption buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Name="MinimizeButton" Classes="TitleBarButton" Click="OnMinimize">
                    <Path Stretch="None" Stroke="#8F909A" StrokeThickness="1.5" Data="M 0,5 L 10,5"
                          Width="10" Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Name="MaximizeButton" Classes="TitleBarButton" Click="OnMaximize">
                    <Path Stretch="None" Stroke="#8F909A" StrokeThickness="1.5" Data="M 1,1 L 9,1 L 9,9 L 1,9 Z"
                          Width="10" Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Name="CloseButton" Classes="TitleBarButton Close" Click="OnClose">
                    <Path Stretch="None" Stroke="#8F909A" StrokeThickness="1.5" Data="M 1,1 L 9,9 M 9,1 L 1,9"
                          Width="10" Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
